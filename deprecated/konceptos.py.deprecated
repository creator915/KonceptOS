#!/usr/bin/env python3
"""
KonceptOS v0.9.1

K = (G, M, I) is a lossy compression of K*.
RW = compression artifact. Concepts = interface contracts.
evolve = vocabulary replacement + redescription (not quotient resolution).

Seeds provide:
  Level 1: vocabulary (legal names)
  Level 2: decomposition tree + incidence hints + conventions
  Level 3: reference K*

Conventions = cross-channel value constraints (e.g. "jump height > platform gap").
They are injected into LLM prompts during build/resolve.
"""

import json,sys,re,time
from pathlib import Path

import os
OPENROUTER_API_KEY = os.environ.get("KONCEPTOS_API_KEY", "")
OPENROUTER_MODEL = os.environ.get("KONCEPTOS_MODEL", "glm-5")
OPENROUTER_URL = os.environ.get("KONCEPTOS_URL", "https://open.bigmodel.cn/api/paas/v4/chat/completions")
VALID_I = {'0','R','W','RW'}

def _ansi():
    if sys.platform!='win32': return True
    try:
        import ctypes;k=ctypes.windll.kernel32;h=k.GetStdHandle(-11)
        m=ctypes.c_ulong();k.GetConsoleMode(h,ctypes.byref(m));k.SetConsoleMode(h,m.value|0x0004);return True
    except: return False
ANSI=_ansi()
class C:
    if ANSI: RST='\033[0m';B='\033[1m';D='\033[2m';R='\033[31m';G='\033[32m';Y='\033[33m';BL='\033[34m';M='\033[35m';CN='\033[36m'
    else: RST=B=D=R=G=Y=BL=M=CN=''
def cc(t,*c): return (''.join(c)+str(t)+C.RST) if ANSI else str(t)

def extract_json(text):
    a,b=text.find('{'),text.rfind('}')
    if a==-1 or b<=a: return None,'No JSON (%d chars)'%len(text)
    s=text[a:b+1]
    try: return json.loads(s),None
    except:
        s2=re.sub(r',\s*}','}',re.sub(r',\s*]',']',s))
        try: return json.loads(s2),None
        except json.JSONDecodeError as e: return None,'pos %d: %s'%(e.pos,e.msg)

# ─── Seed ─────────────────────────────────────────────────────
class Seed:
    def __init__(self):
        self.domain=""
        self.obj_vocab=[];self.attr_vocab=[]
        self.obj_tree={};self.attr_tree={}
        self.incidence_hints={}
        self.conventions=[]  # cross-channel value constraints
        self.reference_k=None

    def lookup_obj(self,name):
        if name in self.obj_tree: return self.obj_tree[name]
        for k,v in self.obj_tree.items():
            if k in name or name in k: return v
        return None

    def lookup_attr(self,name):
        if name in self.attr_tree: return self.attr_tree[name]
        for k,v in self.attr_tree.items():
            if k in name or name in k: return v
        return None

    def has_content(self):
        return bool(self.obj_tree or self.attr_tree or self.obj_vocab or self.conventions or self.reference_k)

    def conventions_text(self):
        return '\n'.join('- '+c for c in self.conventions) if self.conventions else ''

    def to_dict(self):
        return {'domain':self.domain,'obj_vocab':self.obj_vocab,'attr_vocab':self.attr_vocab,
                'obj_tree':self.obj_tree,'attr_tree':self.attr_tree,
                'incidence_hints':self.incidence_hints,'conventions':self.conventions,
                'reference_k':self.reference_k}

    def from_dict(self,d):
        self.domain=d.get('domain','')
        self.obj_vocab=d.get('obj_vocab',[]);self.attr_vocab=d.get('attr_vocab',[])
        self.obj_tree=d.get('obj_tree',{});self.attr_tree=d.get('attr_tree',{})
        self.incidence_hints=d.get('incidence_hints',{})
        self.conventions=d.get('conventions',[])
        self.reference_k=d.get('reference_k')

    def summary(self):
        p=['Seed: %s'%(self.domain or '(unnamed)')]
        if self.obj_vocab: p.append('  L1 obj vocab: %d'%len(self.obj_vocab))
        if self.attr_vocab: p.append('  L1 attr vocab: %d'%len(self.attr_vocab))
        if self.obj_tree: p.append('  L2 obj tree: %d entries'%len(self.obj_tree))
        if self.attr_tree: p.append('  L2 attr tree: %d entries'%len(self.attr_tree))
        if self.incidence_hints: p.append('  L2 hints: %d'%len(self.incidence_hints))
        if self.conventions: p.append('  L2 conventions: %d rules'%len(self.conventions))
        if self.reference_k: p.append('  L3 reference K*: yes')
        return '\n'.join(p)


# ─── LLM ──────────────────────────────────────────────────────
class LLM:
    def __init__(self):
        self.ok=False
        try: import urllib.request; self.ok=bool(OPENROUTER_API_KEY)
        except: pass

    def ask(self,system,user,max_tokens=128000):
        import urllib.request,urllib.error
        body=json.dumps({"model":OPENROUTER_MODEL,"max_tokens":max_tokens,
            "messages":[{"role":"system","content":system},{"role":"user","content":user}]}).encode('utf-8')
        req=urllib.request.Request(OPENROUTER_URL,data=body,headers={
            "Content-Type":"application/json","Authorization":"Bearer "+OPENROUTER_API_KEY,
            "HTTP-Referer":"https://konceptos.local","X-Title":"KonceptOS"},method="POST")
        try:
            with urllib.request.urlopen(req) as resp:
                d=json.loads(resp.read().decode('utf-8'))
                ch=d.get("choices",[])
                return ch[0]["message"]["content"] if ch else "(empty)"
        except urllib.error.HTTPError as e: return "(HTTP %d)"%e.code
        except Exception as e: return "(err: %s)"%str(e)

    def extract_gm(self,text):
        return self.ask("Extract OBJECTS and ATTRIBUTES.\n"
            "ATTRIBUTES = high-level concern dimensions (~6-12).\n"
            "Pure JSON:\n"
            '{"objects":[{"id":"F01","name":"...","desc":"..."},...],\n'
            '"attributes":[{"id":"A","name":"...","desc":"..."},...]}',text,4000)

    def fill_directed(self,text,ops,aps):
        return self.ask("For each (object,attribute) determine: 0/R/W/RW.\n"
           "Per object: comma-separated in attribute order.\n"
           'Pure JSON: {"F01":"R,0,W,RW,...",...}',
           "Objects: %s\nAttributes: %s\nDoc:\n%s"%(
            ', '.join('%s(%s)'%x for x in ops),', '.join('%s(%s)'%x for x in aps),text),4000)

    def judge_one(self,on,od,an,ad):
        r=self.ask("Answer ONLY: 0, R, W, or RW",
            "Feature: %s - %s\nConcern: %s - %s"%(on,od,an,ad),10).strip().upper()
        for v in ['RW','R','W','0']:
            if v in r: return v
        return '0'

    def ask_expansion(self,name,desc,kind,vocab_hint):
        vhint=""
        if vocab_hint:
            vhint="\nChoose from or be inspired by: %s"%', '.join(vocab_hint)
        s=("'%s' compresses multiple distinct %ss.\n"
           "List 2-5 conceptually different sub-%ss (NOT R/W splits).%s\n\n"
           "Pure JSON: {\"expansions\":[{\"name\":\"...\",\"desc\":\"...\"},...]}"
          )%(name,kind,kind,vhint)
        return self.ask(s,"Name: %s\nDesc: %s"%(name,desc),1000)

    def build_full(self,spec,binds,conventions):
        s=("Generate a COMPLETE RUNNABLE single-file HTML+JS webapp from this FCA spec.\n"
           "RW means both reads and writes. Follow the lattice structure.\n"
           "Output ONLY the HTML. No markdown fences.")
        p=""
        if conventions:
            p+="=== CRITICAL CONSTRAINTS (must satisfy ALL) ===\n"+conventions+"\n\n"
        p+=spec
        if binds: p+="\n\nTech Bindings:\n"+binds
        return self.ask(s,p)


# ─── FCA Engine ───────────────────────────────────────────────
class FCA:
    def __init__(self):
        self.objects={};self.attributes={};self.bindings={};self.conventions=""
        self.incidence={};self.concepts=[];self.edges=[];self.layers=[]
        self.history=[];self.snapshots=[]
        self.round=0;self._prev={}
        self.seed=Seed()

    def add_obj(self,oid,name,desc=''):
        self.objects[oid]={'name':name,'desc':desc,'solidified':False}
        for a in self.attributes:
            if (oid,a) not in self.incidence: self.incidence[(oid,a)]='?'
        self._log('add_obj','%s: %s'%(oid,name))

    def add_attr(self,aid,name,desc=''):
        self.attributes[aid]={'name':name,'desc':desc}
        for o in self.objects:
            if (o,aid) not in self.incidence: self.incidence[(o,aid)]='?'
        self._log('add_attr','%s: %s'%(aid,name))

    def set_i(self,oid,aid,val):
        val=val.upper().strip()
        if val in ('1','YES','TRUE'): val='RW'
        if val in ('NO','FALSE','NONE'): val='0'
        if val not in VALID_I: raise ValueError('Use 0/R/W/RW, got "%s"'%val)
        if oid not in self.objects: raise ValueError('No obj: '+oid)
        if aid not in self.attributes: raise ValueError('No attr: '+aid)
        self.incidence[(oid,aid)]=val

    def del_obj(self,oid):
        if oid in self.objects:
            del self.objects[oid]
            self.incidence={k:v for k,v in self.incidence.items() if k[0]!=oid}
    def del_attr(self,aid):
        if aid in self.attributes:
            del self.attributes[aid]
            self.incidence={k:v for k,v in self.incidence.items() if k[1]!=aid}
            self.bindings.pop(aid,None)

    def involved(self,o,a): return self.incidence.get((o,a),'0') in ('R','W','RW')
    def unknowns(self): return [(o,a) for (o,a),v in self.incidence.items() if v=='?']
    def rw_count(self): return sum(1 for v in self.incidence.values() if v=='RW')
    def rw_cells(self): return [(o,a) for (o,a),v in self.incidence.items() if v=='RW']

    def _intent(self,ext):
        if not ext: return set(self.attributes)
        r=set(self.attributes)
        for o in ext: r&={a for a in self.attributes if self.involved(o,a)}
        return r
    def _extent(self,intn):
        if not intn: return set(self.objects)
        r=set(self.objects)
        for a in intn: r&={o for o in self.objects if self.involved(o,a)}
        return r

    def compute(self):
        if not self.objects or not self.attributes:
            self.concepts,self.edges,self.layers=[],[],[];self._snap();return
        seen=set();concepts=[];oids=list(self.objects);aids=list(self.attributes)
        cands=[set()]
        for o in oids: cands.append({o})
        for i in range(len(oids)):
            for j in range(i+1,min(i+10,len(oids))): cands.append({oids[i],oids[j]})
        for a in aids: cands.append(self._extent({a}))
        for i in range(len(aids)):
            for j in range(i+1,len(aids)): cands.append(self._extent({aids[i],aids[j]}))
        if len(aids)<=14:
            for i in range(len(aids)):
                for j in range(i+1,len(aids)):
                    for k2 in range(j+1,len(aids)): cands.append(self._extent({aids[i],aids[j],aids[k2]}))
        for ext in cands:
            intn=self._intent(ext);closed=self._extent(intn)
            key=(frozenset(closed),frozenset(intn))
            if key not in seen: seen.add(key);concepts.append((set(closed),set(intn)))
        concepts.sort(key=lambda c:len(c[1]));self.concepts=concepts
        self.edges=[]
        for i in range(len(concepts)):
            for j in range(i+1,len(concepts)):
                ai,bi=concepts[i][1],concepts[j][1]
                if ai<bi:
                    ok=True
                    for k2 in range(len(concepts)):
                        if k2==i or k2==j:continue
                        if ai<concepts[k2][1]<bi:ok=False;break
                    if ok:self.edges.append((i,j))
        self.layers=[0]*len(concepts);ch=True
        while ch:
            ch=False
            for p,c in self.edges:
                if self.layers[c]<=self.layers[p]:self.layers[c]=self.layers[p]+1;ch=True
        self._snap()

    def _snap(self):
        sc=[{'ext':sorted(ext),'int':sorted(intn),
            'en':[self.objects[o]['name'] for o in sorted(ext) if o in self.objects],
            'an':[self.attributes[a]['name'] for a in sorted(intn) if a in self.attributes]}
            for ext,intn in self.concepts]
        inc={('%s|%s'%(o,a)):v for (o,a),v in self.incidence.items()}
        self.snapshots.append({'round':self.round,'time':time.strftime('%H:%M:%S'),
            'no':len(self.objects),'na':len(self.attributes),'nc':len(self.concepts),
            'rw':self.rw_count(),'unk':len(self.unknowns()),
            'concepts':sc,'edges':list(self.edges),'layers':list(self.layers),'inc':inc})

    def check_consistency(self):
        issues=[]
        for aid in self.attributes:
            rs=[o for o in self.objects if self.incidence.get((o,aid),'0') in ('R','RW')]
            ws=[o for o in self.objects if self.incidence.get((o,aid),'0') in ('W','RW')]
            an=self.attributes[aid]['name']
            if rs and not ws: issues.append('"%s": %d R, no W'%(an,len(rs)))
            if ws and not rs: issues.append('"%s": %d W, no R'%(an,len(ws)))
        return issues

    def coding_groups(self):
        groups={}
        for oid in self.objects:
            best=-1;bisz=-1
            for idx,(ext,intn) in enumerate(self.concepts):
                if oid in ext and len(intn)>bisz: best=idx;bisz=len(intn)
            if best>=0: groups.setdefault(best,[]).append(oid)
        return groups

    def dataflows(self):
        flows=[]
        for aid in self.attributes:
            ws=[o for o in self.objects if self.incidence.get((o,aid),'0') in ('W','RW')]
            rs=[o for o in self.objects if self.incidence.get((o,aid),'0') in ('R','RW')]
            for w in ws:
                for r in rs:
                    if w!=r: flows.append((self.objects[w]['name'],self.attributes[aid]['name'],self.objects[r]['name']))
        return flows

    def get_all_conventions(self):
        """Merge seed conventions + manual conventions"""
        parts=[]
        if self.seed.conventions:
            parts.append('\n'.join('- '+c for c in self.seed.conventions))
        if self.conventions:
            parts.append(self.conventions)
        return '\n'.join(parts)

    # ── Quotient Resolution ──

    def resolve_obj(self,oid,children,llm):
        if oid not in self.objects: return False
        parent=self.objects[oid]
        parent_inc={(oid,a):self.incidence.get((oid,a),'0') for a in self.attributes}
        new_ids=[]
        for i,ch in enumerate(children):
            nid='%s_%d'%(oid,i+1) if not ch.get('id') else ch['id']
            while nid in self.objects: nid+='_'
            self.add_obj(nid,ch['name'],ch.get('desc',''))
            new_ids.append(nid)
        for nid in new_ids:
            nname=self.objects[nid]['name']
            for aid in self.attributes:
                aname=self.attributes[aid]['name']
                pv=parent_inc.get((oid,aid),'0')
                if pv=='0':
                    self.set_i(nid,aid,'0');continue
                # Check seed hints (exact and wildcard)
                hint=self.seed.incidence_hints.get('%s|%s'%(nname,aname))
                if not hint: hint=self.seed.incidence_hints.get('*|%s'%aname)
                if hint and hint.upper() in VALID_I:
                    self.set_i(nid,aid,hint.upper());continue
                v=llm.judge_one(nname,self.objects[nid].get('desc',''),aname,self.attributes[aid].get('desc',''))
                self.set_i(nid,aid,v)
        self.del_obj(oid)
        return True

    def resolve_attr(self,aid,children,llm):
        if aid not in self.attributes: return False
        parent_inc={(o,aid):self.incidence.get((o,aid),'0') for o in self.objects}
        old_binding=self.bindings.pop(aid,None)
        new_aids=[]
        for i,ch in enumerate(children):
            nid='%s_%d'%(aid,i+1) if not ch.get('id') else ch['id']
            while nid in self.attributes: nid+='_'
            self.add_attr(nid,ch['name'],ch.get('desc',''))
            if old_binding: self.bindings[nid]=old_binding
            new_aids.append(nid)
        for oid in list(self.objects.keys()):
            oname=self.objects[oid]['name']
            pv=parent_inc.get((oid,aid),'0')
            if pv=='0':
                for naid in new_aids: self.set_i(oid,naid,'0')
                continue
            for naid in new_aids:
                naname=self.attributes[naid]['name']
                hint=self.seed.incidence_hints.get('%s|%s'%(oname,naname))
                if not hint: hint=self.seed.incidence_hints.get('*|%s'%naname)
                if hint and hint.upper() in VALID_I:
                    self.set_i(oid,naid,hint.upper());continue
                v=llm.judge_one(oname,self.objects[oid].get('desc',''),naname,self.attributes[naid].get('desc',''))
                self.set_i(oid,naid,v)
        self.del_attr(aid)
        return True

    def _log(self,a,d):
        self.history.append({'round':self.round,'time':time.strftime('%H:%M:%S'),'act':a,'detail':d})

    # ── Serialization ──

    def export_spec(self,fp):
        L=['# FCA Spec\n']
        conv=self.get_all_conventions()
        if conv: L.append('## Conventions\n```\n%s\n```\n'%conv)
        L.append('## Objects (%d)\n| ID | Name | Desc |'%len(self.objects))
        L.append('|----|------|------|')
        for o in sorted(self.objects):
            ob=self.objects[o];L.append('| %s | %s | %s |'%(o,ob['name'],ob.get('desc','')))
        L.append('\n## Attributes (%d)\n| ID | Name | Binding |'%len(self.attributes))
        L.append('|----|------|---------| ')
        for a in sorted(self.attributes):
            L.append('| %s | %s | %s |'%(a,self.attributes[a]['name'],self.bindings.get(a,'-')))
        aids=sorted(self.attributes)
        L.append('\n## Incidence\n| |'+'|'.join(self.attributes[a]['name'][:6] for a in aids)+'|')
        L.append('|--'+'|--'*len(aids)+'|')
        for o in sorted(self.objects):
            row='| %s '%self.objects[o]['name'][:14]
            for a in aids: row+='| %s '%self.incidence.get((o,a),'?')
            L.append(row+'|')
        L.append('\n## Concepts (%d)\n'%len(self.concepts))
        if self.concepts:
            ml=max(self.layers) if self.layers else 0
            for layer in range(ml+1):
                lc=[(i,self.concepts[i]) for i in range(len(self.concepts)) if self.layers[i]==layer]
                if not lc:continue
                L.append('### L%d'%layer)
                for idx,(ext,intn) in lc:
                    en=[self.objects[o]['name'] for o in sorted(ext) if o in self.objects]
                    an=[self.attributes[a]['name'] for a in sorted(intn) if a in self.attributes]
                    L.append('C%02d ({%s}, {%s})'%(idx,', '.join(en),', '.join(an) or 'empty'))
                L.append('')
        with open(fp,'w',encoding='utf-8') as f: f.write('\n'.join(L))

    def to_dict(self):
        inc={('%s|%s'%(o,a)):v for (o,a),v in self.incidence.items()}
        return {'objects':self.objects,'attributes':self.attributes,'bindings':self.bindings,
            'conventions':self.conventions,'incidence':inc,'round':self.round,
            'history':self.history[-300:],'snapshots':self.snapshots,
            'seed':self.seed.to_dict()}

    def from_dict(self,d):
        self.objects=d.get('objects',{});self.attributes=d.get('attributes',{})
        self.bindings=d.get('bindings',{});self.conventions=d.get('conventions','')
        self.incidence={}
        for k,v in d.get('incidence',{}).items():
            p=k.split('|')
            if len(p)==2:self.incidence[(p[0],p[1])]=v
        self.round=d.get('round',0)
        self.history=d.get('history',[]);self.snapshots=d.get('snapshots',[])
        if 'seed' in d: self.seed.from_dict(d['seed'])
        self._prev={o:self._objsnap(o) for o in self.objects}
        self.compute()

    def _objsnap(self,o):
        return self.objects[o]['name']+'|'+','.join(
            self.incidence.get((o,a),'?') for a in sorted(self.attributes))


# ─── Display ──────────────────────────────────────────────────
def show_ctx(e):
    if not e.objects or not e.attributes: print(cc('  Empty.',C.D));return
    oids=sorted(e.objects);aids=sorted(e.attributes)
    nw=max(18,max(len(e.objects[o]['name']) for o in oids)+6)
    hdr=' '*nw
    for a in aids: hdr+=cc(e.attributes[a]['name'][:5].center(6),C.CN)
    print(cc('  +'+ '-'*(nw+len(aids)*6)+'+',C.D))
    print('  |'+hdr+'|')
    print(cc('  +'+ '-'*(nw+len(aids)*6)+'+',C.D))
    for o in oids:
        ob=e.objects[o]
        lbl=' %s %s'%(cc(o,C.Y),ob['name']);vl=1+len(o)+1+len(ob['name'])
        row=lbl+' '*max(0,nw-vl)
        for a in aids:
            v=e.incidence.get((o,a),'?')
            if v=='RW':  row+=cc(' RW  ',C.G,C.B)+' '
            elif v=='R': row+=cc('  R   ',C.CN)
            elif v=='W': row+=cc('  W   ',C.M)
            elif v=='0': row+=cc('  .   ',C.D)
            else:        row+=cc('  ?   ',C.R)
        print('  |'+row+'|')
    print(cc('  +'+ '-'*(nw+len(aids)*6)+'+',C.D))

def show_status(e):
    rw=e.rw_count();nu=len(e.unknowns())
    print(cc('  K: |G|=%d |M|=%d RW=%d ?=%d |B|=%d'%(
        len(e.objects),len(e.attributes),rw,nu,len(e.concepts)),C.B))
    if rw==0 and nu==0:
        print(cc('  K* reached (no RW, no ?)',C.G,C.B))
    else:
        if rw: print(cc('  %d RW = %d compressions to resolve'%(rw,rw),C.Y))
        if nu: print(cc('  %d unknowns'%nu,C.R))
    cons=e.check_consistency()
    for c in cons: print('  ! %s'%cc(c,C.Y))
    if e.seed.has_content():
        print(cc('  Seed: %s'%e.seed.domain,C.CN))
    else:
        print(cc('  Seed: none',C.D))
    conv=e.get_all_conventions()
    if conv:
        lines=conv.strip().split('\n')
        print(cc('  Conventions: %d rules'%len(lines),C.CN))

def show_snaps(e):
    if not e.snapshots: print(cc('  None.',C.D));return
    for i,s in enumerate(e.snapshots):
        m='*' if s['rw']==0 and s['unk']==0 else ' '
        print('  %s#%d %s |G|=%d |M|=%d |B|=%d RW=%s ?=%s'%(
            m,i,s['time'],s['no'],s['na'],s['nc'],
            cc(s['rw'],C.Y if s['rw'] else C.G),
            cc(s['unk'],C.R if s['unk'] else C.G)))

def show_diff(e,a,b):
    if a<0 or a>=len(e.snapshots) or b<0 or b>=len(e.snapshots):
        print(cc('  Bad idx',C.R));return
    sa,sb=e.snapshots[a],e.snapshots[b]
    print(cc('  #%d -> #%d'%(a,b),C.B))
    for k,lb in [('no','|G|'),('na','|M|'),('nc','|B|'),('rw','RW'),('unk','?')]:
        va,vb=sa[k],sb[k]
        if va!=vb: print('  %5s: %d -> %d (%+d)'%(lb,va,vb,vb-va))
    ka,kb=sa.get('inc',{}),sb.get('inc',{})
    ch=[(k,ka.get(k,'-'),kb.get(k,'-')) for k in sorted(set(list(ka)+list(kb))) if ka.get(k,'-')!=kb.get(k,'-')]
    if ch:
        print(cc('  Changes:',C.Y))
        for k,va,vb in ch[:20]: print('    %s: %s -> %s'%(k,va,vb))
        if len(ch)>20: print('    +%d'%(len(ch)-20))

def load_file(fp):
    p=Path(fp)
    if not p.exists():
        alt=Path('/mnt/user-data/uploads/'+fp)
        if alt.exists():p=alt
        else: raise FileNotFoundError(fp)
    return p.read_text(encoding='utf-8',errors='replace')


# ─── Main ─────────────────────────────────────────────────────
HELP="""
  ================================================================
   KonceptOS v0.9.1
   K -> K* by vocabulary replacement + redescription
   Seeds: decomposition trees + conventions + incidence hints
  ================================================================

  Basics:
    add obj <id> <n> [| desc]     add attr <id> <n> [| desc]
    set <o> <a> <0|R|W|RW>           row <o> R,0,W,RW,...
    del obj|attr <id>                 bind <a> <tech>
    convention [text]                 view/set manual conventions

  View:
    ctx     st     rw     flows     groups     lat     concept <n>

  Seed:
    seed                   show seed info
    seed load <file>       load seed JSON (auto-loads conventions)
    seed save <file>       save seed
    seed tree              show decomposition trees
    seed conv              show seed conventions
    seed set obj <p> <c1> <c2> ...    add obj decomposition
    seed set attr <p> <c1> <c2> ...   add attr decomposition

  Resolve (vocabulary replacement):
    resolve obj <id>       expand object (seed -> LLM fallback)
    resolve attr <id>      expand attribute (seed -> LLM fallback)
    evolve [n]             auto-resolve n RW cells (default 1)
    evolve all             resolve all until K* or stuck

  LLM:
    llm analyze <f>     llm ask     llm chat <msg>

  Build:
    build [out]            spec + conventions -> LLM -> complete app

  Snapshots:
    snaps     diff <a> <b>     rollback <n>

  compute     save <f>     open <f>     export <f>
  help     hist     quit
"""

def main():
    e=FCA();llm=LLM()
    if len(sys.argv)>2 and sys.argv[1]=='--load':
        try:
            with open(sys.argv[2],'r') as f:e.from_dict(json.load(f))
            print(cc('  Loaded %s'%sys.argv[2],C.G))
        except Exception as ex:print(cc('  %s'%ex,C.R))

    print(cc("""
  +===========================================================+
  |  KonceptOS v0.9.1                                      |
  |  K -> K* by vocabulary replacement                        |
  |  Seeds: trees + conventions + hints                       |
  |  "resolve" expands concepts  |  "build" generates code    |
  +===========================================================+
    """,C.CN))
    print(cc('  LLM: %s'%('Opus 4.6' if llm.ok else 'N/A'),C.G if llm.ok else C.Y))

    while True:
        try: raw=input(cc('  K[%d|%d]'%(len(e.objects),e.rw_count()),C.BL,C.B)+cc('> ',C.D)).strip()
        except (EOFError,KeyboardInterrupt): print('\n  Bye.');break
        if not raw:continue
        parts=raw.split(maxsplit=3);cmd=parts[0].lower()
        try:
            if cmd=='help':print(HELP)
            elif cmd in('quit','exit'):break

            # ── Seed ──
            elif cmd=='seed':
                if len(parts)==1:
                    print(e.seed.summary())
                elif parts[1]=='load' and len(parts)>=3:
                    fp=' '.join(parts[2:])
                    try:
                        d=json.loads(load_file(fp))
                        e.seed.from_dict(d)
                        print(cc('  Loaded seed: %s'%e.seed.domain,C.G))
                        print(e.seed.summary())
                    except Exception as ex: print(cc('  %s'%ex,C.R))
                elif parts[1]=='save' and len(parts)>=3:
                    with open(parts[2],'w',encoding='utf-8') as f:
                        json.dump(e.seed.to_dict(),f,ensure_ascii=False,indent=2)
                    print(cc('  Saved: %s'%parts[2],C.G))
                elif parts[1]=='tree':
                    if e.seed.obj_tree:
                        print(cc('  Object tree:',C.CN))
                        for k,v in sorted(e.seed.obj_tree.items()):
                            print('    %s -> %s'%(cc(k,C.Y),', '.join(v)))
                    if e.seed.attr_tree:
                        print(cc('  Attribute tree:',C.M))
                        for k,v in sorted(e.seed.attr_tree.items()):
                            print('    %s -> %s'%(cc(k,C.Y),', '.join(v)))
                    if not e.seed.obj_tree and not e.seed.attr_tree:
                        print(cc('  Empty.',C.D))
                elif parts[1]=='conv':
                    if e.seed.conventions:
                        print(cc('  Seed conventions (%d):'%len(e.seed.conventions),C.CN))
                        for c in e.seed.conventions: print('    - %s'%c)
                    else:
                        print(cc('  No seed conventions.',C.D))
                elif parts[1]=='set' and len(parts)>=4:
                    rest=raw.split(maxsplit=3)
                    kind=rest[2].lower()
                    tokens=rest[3].split() if len(rest)>3 else []
                    if len(tokens)<2:
                        print(cc('  Usage: seed set obj|attr <parent> <child1> <child2> ...',C.D))
                    else:
                        parent=tokens[0];children=tokens[1:]
                        if kind in('obj','object'):
                            e.seed.obj_tree[parent]=children
                            print(cc('  %s -> %s'%(parent,', '.join(children)),C.G))
                        elif kind in('attr','attribute'):
                            e.seed.attr_tree[parent]=children
                            print(cc('  %s -> %s'%(parent,', '.join(children)),C.G))
                else:
                    print(cc('  seed / load / save / tree / conv / set',C.D))

            # ── LLM ──
            elif cmd=='llm' and len(parts)>=2:
                sub=parts[1].lower()
                if sub=='analyze' and len(parts)>=3:
                    fp=' '.join(parts[2:])
                    try:content=load_file(fp)
                    except Exception as ex:print(cc('  %s'%ex,C.R));continue
                    print(cc('  [1/2] G,M...',C.D))
                    r1=llm.extract_gm(content);d1,err=extract_json(r1)
                    if not d1:print(cc('  Fail: %s'%err,C.R));print(r1[:500]);continue
                    for obj in d1.get('objects',[]):
                        oid=obj.get('id','')
                        if oid:e.add_obj(oid,obj.get('name',oid),obj.get('desc',''));print('    +%s %s'%(oid,obj.get('name','')))
                    for at in d1.get('attributes',[]):
                        aid=at.get('id','')
                        if aid:e.add_attr(aid,at.get('name',aid),at.get('desc',''));print('    +%s %s'%(aid,at.get('name','')))
                    no=len(e.objects);na=len(e.attributes)
                    if no==0 or na==0:continue
                    op=[(o,e.objects[o]['name']) for o in sorted(e.objects)]
                    ap=[(a,e.attributes[a]['name']) for a in sorted(e.attributes)]
                    print(cc('  [2/2] %dx%d directed I...'%(no,na),C.D))
                    r2=llm.fill_directed(content,op,ap);d2,_=extract_json(r2)
                    if not d2:e.compute();print(cc('  I failed.',C.R));continue
                    cnt=0;aids=sorted(e.attributes)
                    for key,val in d2.items():
                        if isinstance(val,str) and key in e.objects:
                            for i,cell in enumerate(c.strip().upper() for c in val.split(',')):
                                if i<len(aids):
                                    cv=cell
                                    if cv in('1','YES'):cv='RW'
                                    if cv in VALID_I:
                                        try:e.set_i(key,aids[i],cv);cnt+=1
                                        except:pass
                    e.compute()
                    print(cc('  K: |G|=%d |M|=%d RW=%d ?=%d |B|=%d'%(
                        len(e.objects),len(e.attributes),e.rw_count(),len(e.unknowns()),len(e.concepts)),C.G))
                    for c in e.check_consistency():print('  ! %s'%cc(c,C.Y))

                elif sub=='ask':
                    unks=e.unknowns()
                    if not unks:print(cc('  Complete!',C.G));continue
                    skip_all=False
                    for oid,aid in unks:
                        if skip_all:
                            v=llm.judge_one(e.objects[oid]['name'],e.objects[oid].get('desc',''),e.attributes[aid]['name'],e.attributes[aid].get('desc',''))
                            e.set_i(oid,aid,v);print('    %s x %s = %s'%(e.objects[oid]['name'],e.attributes[aid]['name'],v));continue
                        a=input('    %s x %s ? '%(cc(e.objects[oid]['name'],C.CN),cc(e.attributes[aid]['name'],C.M))).strip().upper()
                        if a=='Q':break
                        elif a in('SA','SKIPALL'):
                            skip_all=True;v=llm.judge_one(e.objects[oid]['name'],e.objects[oid].get('desc',''),e.attributes[aid]['name'],e.attributes[aid].get('desc',''))
                            e.set_i(oid,aid,v);print('    = %s'%v)
                        elif a in('S','SKIP'):
                            v=llm.judge_one(e.objects[oid]['name'],e.objects[oid].get('desc',''),e.attributes[aid]['name'],e.attributes[aid].get('desc',''))
                            e.set_i(oid,aid,v);print('    = %s'%v)
                        elif a in VALID_I:e.set_i(oid,aid,a)
                    e.compute();print(cc('  %d remaining'%len(e.unknowns()),C.D))

                elif sub=='chat':
                    msg=raw.split(maxsplit=2)
                    if len(msg)<3:continue
                    print('  '+llm.ask("FCA assistant.",msg[2]).replace('\n','\n  '))
                else:print(cc('  llm analyze|ask|chat',C.D))

            # ── resolve ──
            elif cmd=='resolve' and len(parts)>=3:
                kind=parts[1].lower();xid=parts[2]
                if kind in('obj','object'):
                    if xid not in e.objects:print(cc('  No obj: %s'%xid,C.R));continue
                    ob=e.objects[xid]
                    children=e.seed.lookup_obj(ob['name'])
                    if children:
                        print(cc('  Seed: %s -> %s'%(ob['name'],', '.join(children)),C.CN))
                        ch_list=[{'name':c} for c in children]
                    else:
                        print(cc('  No seed. Asking LLM...',C.D))
                        vocab=e.seed.obj_vocab or None
                        r=llm.ask_expansion(ob['name'],ob.get('desc',''),'object',vocab)
                        d,err=extract_json(r)
                        if not d or 'expansions' not in d:
                            print(cc('  Failed: %s'%(err or r[:200]),C.R));continue
                        ch_list=d['expansions']
                        print(cc('  LLM: %s -> %s'%(ob['name'],', '.join(c['name'] for c in ch_list)),C.CN))
                    ans=input(cc('  Proceed? (y/n/edit) ',C.Y)).strip().lower()
                    if ans=='n':continue
                    if ans=='edit':
                        names=input('  Children (space-separated): ').strip().split()
                        ch_list=[{'name':n} for n in names]
                    print(cc('  Resolving...',C.D))
                    e.resolve_obj(xid,ch_list,llm);e.compute()
                    print(cc('  Done. RW=%d |G|=%d |M|=%d |B|=%d'%(e.rw_count(),len(e.objects),len(e.attributes),len(e.concepts)),C.G))

                elif kind in('attr','attribute'):
                    if xid not in e.attributes:print(cc('  No attr: %s'%xid,C.R));continue
                    at=e.attributes[xid]
                    children=e.seed.lookup_attr(at['name'])
                    if children:
                        print(cc('  Seed: %s -> %s'%(at['name'],', '.join(children)),C.CN))
                        ch_list=[{'name':c} for c in children]
                    else:
                        print(cc('  No seed. Asking LLM...',C.D))
                        vocab=e.seed.attr_vocab or None
                        r=llm.ask_expansion(at['name'],at.get('desc',''),'attribute',vocab)
                        d,err=extract_json(r)
                        if not d or 'expansions' not in d:
                            print(cc('  Failed: %s'%(err or r[:200]),C.R));continue
                        ch_list=d['expansions']
                        print(cc('  LLM: %s -> %s'%(at['name'],', '.join(c['name'] for c in ch_list)),C.CN))
                    ans=input(cc('  Proceed? (y/n/edit) ',C.Y)).strip().lower()
                    if ans=='n':continue
                    if ans=='edit':
                        names=input('  Children (space-separated): ').strip().split()
                        ch_list=[{'name':n} for n in names]
                    print(cc('  Resolving...',C.D))
                    e.resolve_attr(xid,ch_list,llm);e.compute()
                    print(cc('  Done. RW=%d |G|=%d |M|=%d |B|=%d'%(e.rw_count(),len(e.objects),len(e.attributes),len(e.concepts)),C.G))
                else:
                    print(cc('  resolve obj|attr <id>',C.D))

            # ── evolve ──
            elif cmd=='evolve':
                if not e.concepts:e.compute()
                rw=e.rw_count()
                if rw==0:print(cc('  K* (RW=0)',C.G));continue
                mx=rw*3 if len(parts)>1 and parts[1]=='all' else (int(parts[1]) if len(parts)>1 else 1)
                init_snap=len(e.snapshots)-1;init_rw=rw
                print(cc('  === Evolve: %d RW ==='%rw,C.B))
                for step in range(1,mx+1):
                    cells=e.rw_cells()
                    if not cells:print(cc('\n  K* reached!',C.G,C.B));break
                    obj_rw={}
                    for o,a in cells: obj_rw[o]=obj_rw.get(o,0)+1
                    worst=max(obj_rw,key=obj_rw.get)
                    oname=e.objects[worst]['name']
                    children=e.seed.lookup_obj(oname)
                    if children:
                        print(cc('\n  [%d] %s -> %s (seed)'%(step,oname,', '.join(children)),C.CN))
                        ch_list=[{'name':c} for c in children]
                    else:
                        print(cc('\n  [%d] %s (LLM)...'%(step,oname),C.Y))
                        vocab=e.seed.obj_vocab or None
                        r=llm.ask_expansion(oname,e.objects[worst].get('desc',''),'object',vocab)
                        d,_=extract_json(r)
                        if not d or 'expansions' not in d:
                            print(cc('    Failed, skipping',C.R));break
                        ch_list=d['expansions']
                        print(cc('    -> %s'%', '.join(c['name'] for c in ch_list),C.CN))
                    e.resolve_obj(worst,ch_list,llm);e.compute()
                    new_rw=e.rw_count()
                    print(cc('    RW: %d -> %d  |G|=%d |M|=%d'%(rw,new_rw,len(e.objects),len(e.attributes)),
                        C.G if new_rw<rw else C.Y))
                    rw=new_rw
                print(cc('\n  RW %d->%d  |G| %d->%d  |M| %d->%d'%(
                    init_rw,e.rw_count(),
                    e.snapshots[init_snap]['no'],len(e.objects),
                    e.snapshots[init_snap]['na'],len(e.attributes)),C.G))

            # ── build ──
            elif cmd=='build':
                if not e.concepts:e.compute()
                sp='_build_spec.md';e.export_spec(sp)
                st=Path(sp).read_text(encoding='utf-8')
                bt='\n'.join('%s:%s'%(e.attributes.get(a,{}).get('name',a),t) for a,t in e.bindings.items()) if e.bindings else ''
                conv=e.get_all_conventions()
                print(cc('  Building... (conventions: %d rules)'%(len(conv.split('\n')) if conv else 0),C.D))
                r=llm.build_full(st,bt,conv)
                out=parts[1] if len(parts)>1 else 'build_output.html'
                # Strip markdown fences if present
                if r.strip().startswith('```'):
                    lines=r.strip().split('\n')
                    if lines[0].startswith('```'): lines=lines[1:]
                    if lines and lines[-1].startswith('```'): lines=lines[:-1]
                    r='\n'.join(lines)
                with open(out,'w',encoding='utf-8') as f:f.write(r)
                print(cc('  %s (%d chars)'%(out,len(r)),C.G))

            # ── basics ──
            elif cmd=='add' and len(parts)>=3:
                kind=parts[1].lower();rest=raw.split(maxsplit=3)
                xid=rest[2];name=rest[3] if len(rest)>3 else xid;desc=''
                if '|' in name:name,desc=name.split('|',1);name=name.strip();desc=desc.strip()
                if kind in('obj','object'):e.add_obj(xid,name,desc);print(cc('  +%s'%xid,C.G))
                elif kind in('attr','attribute'):e.add_attr(xid,name,desc);print(cc('  +%s'%xid,C.G))
            elif cmd=='del' and len(parts)>=3:
                kind=parts[1].lower();xid=parts[2]
                if kind in('obj','object'):e.del_obj(xid)
                elif kind in('attr','attribute'):e.del_attr(xid)
                print(cc('  -%s'%xid,C.G))
            elif cmd=='set' and len(parts)>=4:
                e.set_i(parts[1],parts[2],parts[3]);print(cc('  OK',C.G))
            elif cmd=='row' and len(parts)>=3:
                oid=parts[1];vals=raw.split(maxsplit=2)[2].split(',');aids=sorted(e.attributes)
                for i,v in enumerate(vals):
                    if i<len(aids):e.set_i(oid,aids[i],v.strip())
                print(cc('  OK',C.G))
            elif cmd=='bind' and len(parts)>=3:
                aid=parts[1];tech=' '.join(parts[2:])
                if aid not in e.attributes:print(cc('  ?',C.R));continue
                e.bindings[aid]=tech;print(cc('  %s->%s'%(aid,tech),C.G))
            elif cmd=='convention':
                if len(parts)>1:
                    e.conventions=' '.join(parts[1:]);print(cc('  Set (%d chars)'%len(e.conventions),C.G))
                else:
                    conv=e.get_all_conventions()
                    if conv: print(conv)
                    else: print(cc('  (empty)',C.D))

            # ── view ──
            elif cmd in('ctx','context'):show_ctx(e)
            elif cmd in('st','status'):show_status(e)
            elif cmd=='rw':
                cells=e.rw_cells()
                if not cells:print(cc('  RW=0 (K*)',C.G))
                else:
                    by_obj={}
                    for o,a in cells: by_obj.setdefault(o,[]).append(a)
                    print(cc('  %d RW:'%len(cells),C.Y))
                    for o in sorted(by_obj,key=lambda x:-len(by_obj[x])):
                        attrs=', '.join(e.attributes[a]['name'] for a in by_obj[o])
                        print('    %s (%d): %s'%(cc(e.objects[o]['name'],C.CN),len(by_obj[o]),cc(attrs,C.M)))
            elif cmd=='flows':
                fl=e.dataflows()
                if not fl:print(cc('  None.',C.D))
                else:
                    for frn,vn,ton in fl: print('  %s -[%s]-> %s'%(cc(frn,C.CN),cc(vn,C.M),cc(ton,C.G)))
            elif cmd=='groups':
                gr=e.coding_groups()
                print(cc('  %d groups:'%len(gr),C.B))
                for cidx in sorted(gr):
                    names=[e.objects[o]['name'] for o in gr[cidx] if o in e.objects]
                    print('  C%02d: %s'%(cidx,cc(', '.join(names),C.CN)))
            elif cmd in('lat','lattice'):
                if not e.concepts:print(cc('  Empty.',C.D));continue
                ml=max(e.layers) if e.layers else 0
                print(cc('  B(K): %d concepts'%len(e.concepts),C.B))
                tags=['T','L1','L2','L3','L4','L5','L6','L7']
                for layer in range(ml+1):
                    lc=[(i,e.concepts[i]) for i in range(len(e.concepts)) if e.layers[i]==layer]
                    if not lc:continue
                    print(cc('  -- %s --'%(tags[layer] if layer<len(tags) else 'L%d'%layer),C.BL))
                    for idx,(ext,intn) in lc:
                        en=[e.objects[o]['name'][:12] for o in sorted(ext) if o in e.objects]
                        an=[e.attributes[a]['name'][:8] for a in sorted(intn) if a in e.attributes]
                        print('    C%02d {%s} <- {%s}'%(idx,cc(','.join(an),C.M),cc(','.join(en[:5]),C.CN)))
            elif cmd=='concept' and len(parts)>=2:
                idx=int(parts[1])
                if idx<0 or idx>=len(e.concepts):print(cc('  ?',C.R));continue
                ext,intn=e.concepts[idx]
                print(cc('  C%02d L%d'%(idx,e.layers[idx] if idx<len(e.layers) else 0),C.B))
                print(cc('  Intent:',C.M))
                for a in sorted(intn):print('    %s'%e.attributes.get(a,{}).get('name',''))
                print(cc('  Extent:',C.CN))
                for o in sorted(ext):
                    dirs=[e.attributes.get(a,{}).get('name','')[:4]+':'+e.incidence.get((o,a),'?') for a in sorted(intn)]
                    print('    %s  %s'%(e.objects.get(o,{}).get('name',''),cc(' '.join(dirs),C.D)))

            # ── snapshots ──
            elif cmd=='snaps':show_snaps(e)
            elif cmd=='diff' and len(parts)>=3:show_diff(e,int(parts[1]),int(parts[2]))
            elif cmd=='rollback' and len(parts)>=2:
                idx=int(parts[1])
                if idx<0 or idx>=len(e.snapshots):print(cc('  ?',C.R));continue
                s=e.snapshots[idx];e.incidence={}
                for k,v in s['inc'].items():
                    p=k.split('|')
                    if len(p)==2:e.incidence[(p[0],p[1])]=v
                e.compute();print(cc('  Rolled back to #%d'%idx,C.G))

            # ── files ──
            elif cmd=='compute':e.compute();print(cc('  |B|=%d (snap #%d)'%(len(e.concepts),len(e.snapshots)-1),C.G))
            elif cmd=='save' and len(parts)>=2:
                with open(parts[1],'w',encoding='utf-8') as f:json.dump(e.to_dict(),f,ensure_ascii=False,indent=2)
                print(cc('  %s'%parts[1],C.G))
            elif cmd=='open' and len(parts)>=2:
                try:
                    with open(parts[1],'r',encoding='utf-8') as f:e.from_dict(json.load(f))
                    print(cc('  %s (%d snaps)'%(parts[1],len(e.snapshots)),C.G))
                except Exception as ex:print(cc('  %s'%ex,C.R))
            elif cmd=='export' and len(parts)>=2:
                e.export_spec(parts[1]);print(cc('  %s'%parts[1],C.G))
            elif cmd in('hist','history'):
                for h in e.history[-20:]:print(cc('  [%s] %s: %s'%(h['time'],h['act'],h['detail']),C.D))
            else:print(cc('  ? %s'%raw,C.R))
        except Exception as ex:
            print(cc('  ERR: %s'%ex,C.R))
            import traceback;traceback.print_exc()

if __name__=='__main__':main()
